FROM golang:1.26.3-trixie AS builder
ARG VERSION=dev
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build \
    -ldflags="-s -w -X 'github.com/nicklasfrahm-dev/platform/cmd/skatd.version=${VERSION}'" \
    -o /bin/skatd \
    ./cmd/skatd

FROM gcr.io/distroless/static-debian13:nonroot
COPY --from=builder /bin/skatd /skatd
EXPOSE 8080
ENTRYPOINT ["/skatd", "serve"]
